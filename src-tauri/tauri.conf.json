{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GoodbyeDPI Turkey Interface",
  "version": "0.1.0",
  "identifier": "com.akif.goodbyedpi-interface",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "GoodbyeDPI Turkey Interface",
        "width": 1360,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    },
    "resources": {
      "../resources/goodbyedpi/": "goodbyedpi/"
    }
  }
}

